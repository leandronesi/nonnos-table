# Override opzionali (precedenza su config.yaml).
# Copia in `.env` e personalizza.

# Path esplicito a Stockfish (es. C:/Tools/stockfish/stockfish.exe).
STOCKFISH_PATH=

# Override veloce dell'username (utile per testare un altro account senza toccare config.yaml).
CHESS_USERNAME=

# Coach LLM (gpt-5.4-mini). In locale: incolla qui la key per testare il
# coaching narrativo. In CI è iniettata come secret OPENAI_API_KEY.
# Se vuota o manca: coach.py va in fallback regole.
OPENAI_API_KEY=
