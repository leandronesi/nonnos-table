# Nonno's Table — variabili d'ambiente FE.
# Copia in .env.local e riempi con i valori del TUO progetto Supabase.
# .env.local è gitignored. NON committare valori reali.

# Project URL (es. https://abcdefghij.supabase.co)
VITE_SUPABASE_URL=

# anon key (è sicuro lato browser — RLS protegge le tabelle).
VITE_SUPABASE_ANON_KEY=

# Base path GH Pages (vuoto = "/" per dev locale).
# In CI passa VITE_BASE='/mygotham/' o il path del repo.
# VITE_BASE=/

# URL del modello Maia-3 ONNX (43 MB).
# Lascia vuoto per usare il default same-origin: <BASE_URL>maia3/maia3_simplified.onnx
# Alternativa: URL Supabase Storage (cross-origin OK in modalità single-thread).
# Il modello NON è committato nel repo — ospitalo tu (GH Release asset o Supabase Storage).
VITE_MAIA_MODEL_URL=
